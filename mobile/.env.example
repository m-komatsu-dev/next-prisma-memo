# Expo Go / local simulator default.
# iOS Simulator: http://localhost:3000
# Android Emulator: http://10.0.2.2:3000
# Android physical device: http://<your-pc-lan-ip>:3000
EXPO_PUBLIC_API_BASE_URL="http://localhost:3000"

# Preview / production EAS builds use the public Next.js API URL from eas.json:
# EXPO_PUBLIC_API_BASE_URL="https://next-prisma-memo.vercel.app"
#
# Do not add Gemini API keys, DATABASE_URL, AUTH_SECRET, MOBILE_AUTH_SECRET,
# CRON_SECRET, EXPO_ACCESS_TOKEN, refresh tokens, or any other secret to
# mobile/.env. Values prefixed with EXPO_PUBLIC_ are embedded into the app
# bundle.
