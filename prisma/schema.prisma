generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String?   @db.Text // ← ハッシュ保存前提で長さ確保
  emailVerified DateTime?
  image         String?

  accounts          Account[]
  sessions          Session[]
  apiSessions       ApiSession[]
  posts             Post[]
  postShares        PostShare[]
  pushSubscriptions PushSubscription[]

  createdAt DateTime @default(now()) // ← 監査ログ
  updatedAt DateTime @updatedAt
}

model Post {
  id        Int     @id @default(autoincrement())
  title     String
  content   String
  published Boolean @default(false)

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  tags      Tag[]
  shares    PostShare[]
  todoItems TodoItem[]

  @@index([authorId]) // ← パフォーマンス + DoS耐性
  @@index([authorId, updatedAt])
  @@index([authorId, createdAt])
}

model TodoItem {
  id             Int       @id @default(autoincrement())
  postId         Int
  post           Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  text           String
  completed      Boolean   @default(false)
  dueAt          DateTime?
  reminderAt     DateTime?
  reminderSentAt DateTime?
  position       Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([postId])
  @@index([postId, position])
  @@index([postId, completed])
  @@index([dueAt])
  @@index([reminderAt])
  @@index([reminderAt, reminderSentAt, completed])
}

model PushSubscription {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expoPushToken String    @unique
  platform      String?
  deviceName    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  revokedAt     DateTime?

  @@index([userId])
  @@index([userId, revokedAt])
  @@index([revokedAt])
}

enum PostShareRole {
  viewer
  editor
}

model PostShare {
  id        Int           @id @default(autoincrement())
  postId    Int
  post      Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      PostShareRole @default(viewer)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
  @@index([userId, role])
}

model Tag {
  id    Int    @id @default(autoincrement())
  name  String @unique // タグ名は重複しないようにする
  posts Post[] // 1つのタグは複数の投稿に紐づく
}

model Account {
  id     String @id @default(cuid())
  userId String

  type              String
  provider          String
  providerAccountId String

  refresh_token String? @db.Text
  access_token  String? @db.Text
  expires_at    Int?
  token_type    String?
  scope         String?
  id_token      String? @db.Text
  session_state String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([provider, providerAccountId])
  @@index([userId]) // ← クエリ最適化
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expires]) // ← 期限切れ削除高速化
}

model ApiSession {
  id               String    @id @default(cuid())
  userId           String
  refreshTokenHash String    @unique @db.Text
  expiresAt        DateTime
  revokedAt        DateTime?
  lastUsedAt       DateTime?
  userAgent        String?   @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model VerificationToken {
  identifier String
  token      String // ← ハッシュ保存前提（重要）
  expires    DateTime

  @@unique([identifier, token])
  @@index([expires]) // ← 期限切れ削除用
}
